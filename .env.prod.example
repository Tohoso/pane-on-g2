# pane-on-g2 production env
NODE_ENV=production
PANE_ON_G2_BIND=127.0.0.1
PANE_ON_G2_PORT=3457
PANE_ON_G2_TOKEN=replace-me
PANE_ON_G2_STT_PROVIDER=none

# Optional:
# PANE_ON_G2_TOKEN_FILE=/path/to/token
# PANE_ON_G2_LABEL=g2
# PANE_ON_G2_TMUX_PREFIX=
# PANE_ON_G2_SLOTS=cc,alpha,beta,gamma
# PANE_ON_G2_SESSION_CWD=/path/to/claude/project
# GROQ_API_KEY=replace-me
